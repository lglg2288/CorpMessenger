<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             Background="#111118">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Шапка -->
        <Border Grid.Row="0"
                Background="#1C1C28"
                BorderBrush="#2A2A3A"
                BorderThickness="0,0,0,1"
                Padding="16,14">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Кнопка назад -->
                <Button Grid.Column="0"
                        x:Name="BackButton"
                        Content="&#8592;"
                        Command="{Binding BackToChatsListCommand}"
                        Padding="10,8"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#2A2A3E"
                        Foreground="#9090C8"
                        BorderThickness="0"
                        CornerRadius="8"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"/>

                <!-- Имя собеседника -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="ChatTitleTextBlock"
                               Text="{Binding Chatname}"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="#E8E8F0"/>
                    <TextBlock Text="в сети"
                               FontSize="12"
                               Foreground="#5B5BF6"/>
                </StackPanel>

                <!-- Кнопка звонка -->
                <Button Grid.Column="2"
                        x:Name="Call"
                        Content="&#128222;"
                        Command="{Binding CallCommand}"
                        Padding="10,8"
                        FontSize="18"
                        Background="#1A2A1A"
                        Foreground="#4CAF50"
                        BorderBrush="#2A3A2A"
                        BorderThickness="1"
                        CornerRadius="8"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Область сообщений -->
        <ScrollViewer Grid.Row="1"
                      Background="#111118"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="12,8">
            <ItemsControl ItemsSource="{Binding Messages}" Margin="0,4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="6"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MessageItem">
                        <Border Background="{Binding IsMyMessage, Converter={StaticResource MessageBackgroundConverter}}"
                                CornerRadius="14"
                                Padding="12,8"
                                MaxWidth="300"
                                HorizontalAlignment="{Binding IsMyMessage, Converter={StaticResource MessageAlignmentConverter}}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Sender}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding IsMyMessage, Converter={StaticResource MessageSenderColorConverter}}"/>
                                <TextBlock Text="{Binding Text}"
                                           Foreground="#E8E8F0"
                                           FontSize="14"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}"
                                           FontSize="11"
                                           Foreground="#55556A"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Панель ввода -->
        <Border Grid.Row="2"
                Background="#1C1C28"
                BorderBrush="#2A2A3A"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Name="MessageTextBox"
                         Watermark="Напишите сообщение..."
                         Background="#13131E"
                         Foreground="#E8E8F0"
                         BorderBrush="#2E2E42"
                         BorderThickness="1"
                         CornerRadius="20,0,0,20"
                         Padding="16,10"
                         FontSize="14"
                         Text="{Binding MessageInput}"/>
                <Button Grid.Column="1"
                        Name="SendButton"
                        Content="&#10148;"
                        Command="{Binding SendMessageAsyncCommand}"
                        Padding="16,10"
                        FontSize="16"
                        Background="#5B5BF6"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="0,20,20,0"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
