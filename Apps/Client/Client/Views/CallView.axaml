<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Client.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="Client.Views.CallView"
             x:DataType="vm:CallViewModel"
             Background="#111118">

    <Grid RowDefinitions="*,Auto,*">

        <!-- Центральная часть: аватар + имя + статус -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Spacing="20">

            <!-- Аватар -->
            <Border Width="120" Height="120"
                    CornerRadius="60"
                    Background="#2E2E50"
                    HorizontalAlignment="Center">
                <TextBlock Text="{Binding FriendName[0]}"
                           FontSize="52"
                           FontWeight="Bold"
                           Foreground="#9090C8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Имя -->
            <TextBlock Text="{Binding FriendName}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#E8E8F0"
                       HorizontalAlignment="Center"/>

            <!-- Статус -->
            <TextBlock Text="{Binding CallStatus}"
                       FontSize="15"
                       Foreground="#6B6B80"
                       HorizontalAlignment="Center"/>

            <!-- Кнопка сброса -->
            <Border Width="72" Height="72"
                    CornerRadius="36"
                    Background="#C0392B"
                    HorizontalAlignment="Center"
                    Margin="0,40,0,0">
                <Button Command="{Binding HangUpCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="72" Height="72"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                    <TextBlock Text="&#128222;"
                               FontSize="28"
                               RenderTransform="rotate(135deg)"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Border>

            <TextBlock Text="Сбросить"
                       FontSize="13"
                       Foreground="#6B6B80"
                       HorizontalAlignment="Center"/>

        </StackPanel>

    </Grid>
</UserControl>
